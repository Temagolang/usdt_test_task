# gRPC server port
GRPC_PORT=50051

# HTTP server port (healthz endpoint)
HTTP_PORT=8080

# PostgreSQL connection string
DATABASE_DSN=postgres://postgres:postgres@localhost:5432/rates?sslmode=disable

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Grinex API base URL
GRINEX_URL=https://grinex.io
